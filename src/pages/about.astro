              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <!-- Work Experience -->
    <section class="section">
      <div class="container">
        <SectionHeading title="工作经历" subtitle={`${totalYears} 年前端开发，从工程师到开发主管`} />
        <div class="flex flex-col gap-0">
          {workExperience.map((item, index) => (
            <div class="reveal flex gap-4" style={`transition-delay: ${index * 80}ms`}>
              <div class="flex flex-col items-center flex-shrink-0">
                <span class="w-3 h-3 rounded-full bg-[var(--color-accent)] border-2 border-[var(--color-bg)] flex-shrink-0" style="box-shadow: 0 0 0 2px var(--color-accent);"></span>
                {index < workExperience.length - 1 && <span class="w-0.5 flex-1 min-h-[40px] bg-[var(--color-border)] my-1"></span>}
              </div>
              <div class="pb-8 flex-1">
                <span class="text-sm font-bold text-[var(--color-accent)]">{item.period}</span>
                <h3 class="text-lg font-bold mt-1 mb-0">{item.title}</h3>
                <span class="text-sm text-[var(--color-text-muted)] block mb-3">{item.org}</span>
                <ul class="m-0 mb-3 pl-4">
                  {item.responsibilities.map(resp => (
                    <li class="text-sm text-[var(--color-text-secondary)] leading-relaxed list-disc mb-1">{resp}</li>
                  ))}
                </ul>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="text-xs text-[var(--color-text-muted)] font-semibold">参与项目：</span>
                  {item.projects.map(p => (
                    <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium text-[var(--color-tech)] bg-[var(--color-tech-bg)] border border-transparent transition-all hover:border-[var(--color-tech)]">{p}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="section">
      <div class="container">
        <SectionHeading title="项目经历" subtitle="点击项目卡片查看详细技术方案" />
        <div class="reveal">
          <ProjectShowcase client:visible projects={projects} />
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="section">
      <div class="container">
        <SectionHeading title="教育经历" subtitle="持续学习，不断成长" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {education.map((edu, index) => (
            <Card class={`reveal p-6 hover:border-[var(--color-accent)] hover:shadow-md`} style={`transition-delay: ${index * 80}ms`}>
              <div class="text-sm font-bold text-[var(--color-accent)] mb-2">{edu.period}</div>
              <h3 class="text-lg font-bold mb-1">{edu.school}</h3>
              <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--color-text-muted)]">
                <span>{edu.major}</span>
                <span class="text-[var(--color-border-strong)]">·</span>
                <span>{edu.degree}</span>
                <span class="text-[var(--color-border-strong)]">·</span>
                <span>{edu.mode}</span>
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <!-- Quote -->
    <section class="section">
      <div class="container">
        <div class="reveal text-center py-12 rounded-2xl text-white" style="background: linear-gradient(135deg, #38BDF8 0%, #C084FC 50%, #FB923C 100%);">
          <Quote class="w-12 h-12 text-white/30 mx-auto mb-4" />
          <p class="text-xl sm:text-2xl font-semibold leading-relaxed text-white mb-4 max-w-[600px] mx-auto">
            学习能力强，为人谦和，有团队意识。<br />
            善于思考，能通过多种途径寻求解决问题的方案。<br />
            喜欢迎接新的挑战。
          </p>
          <p class="text-sm text-white/70 font-medium">- 王煦澄</p>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    reveals.forEach((el) => observer.observe(el));
  });
</script>
