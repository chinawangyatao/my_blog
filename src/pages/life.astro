---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import PhotoWall from '../components/react/PhotoWall.tsx';
import fs from 'fs';
import path from 'path';

const mediaDir = path.resolve('public/images/life');

interface MediaItem {
  src: string;
  name: string;
  type: 'image' | 'video';
}

let mediaItems: MediaItem[] = [];

if (fs.existsSync(mediaDir)) {
  const files = fs.readdirSync(mediaDir).sort().reverse();
  const imageExts = ['.jpg', '.jpeg', '.png', '.webp', '.avif', '.gif', '.bmp'];
  const videoExts = ['.mp4', '.webm', '.mov', '.avi', '.mkv'];

  for (const file of files) {
    const ext = path.extname(file).toLowerCase();
    const src = `/images/life/${encodeURIComponent(file)}`;

    if (imageExts.includes(ext)) {
      mediaItems.push({ src, name: file, type: 'image' });
    } else if (videoExts.includes(ext)) {
      mediaItems.push({ src, name: file, type: 'video' });
    }
  }
}

const photoCount = mediaItems.filter(m => m.type === 'image').length;
const videoCount = mediaItems.filter(m => m.type === 'video').length;
---

<Layout title="生活 - wxc 的博客" description="记录旅行、日常与生活中的小确幸" category="life">
  <div class="life-page container">
    <!-- Header -->
    <header class="page-header reveal">
      <div class="header-content">
        <SectionTitle
          title="生活"
          subtitle="记录旅行、日常与生活中的小确幸"
          category="life"
        />
        {mediaItems.length > 0 && (
          <div class="media-stats">
            {photoCount > 0 && <span class="stat-pill">📷 {photoCount} 张照片</span>}
            {videoCount > 0 && <span class="stat-pill">🎬 {videoCount} 个视频</span>}
          </div>
        )}
      </div>
      <div class="header-deco">
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
      </div>
    </header>

    {mediaItems.length > 0 ? (
      <div class="reveal reveal-delay-1">
        <PhotoWall client:load items={mediaItems} />
      </div>
    ) : (
      <div class="empty-state reveal">
        <div class="empty-icon">📷</div>
        <p>还没有照片，把照片放到 <code>public/images/life/</code> 目录下即可自动展示</p>
      </div>
    )}
  </div>
</Layout>

<style>
  .life-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .page-header {
    position: relative;
    margin-bottom: var(--space-8);
    overflow: hidden;
  }

  .header-content {
    position: relative;
    z-index: 1;
  }

  .media-stats {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }

  .stat-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-life);
    background: color-mix(in srgb, #FB923C 12%, transparent);
    border: 1px solid color-mix(in srgb, #FB923C 25%, transparent);
  }

  .header-deco {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    pointer-events: none;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.2;
  }

  .deco-circle-1 {
    width: 150px;
    height: 150px;
    background: var(--color-life);
    top: 0;
    right: 0;
  }

  .deco-circle-2 {
    width: 100px;
    height: 100px;
    background: #E89B7A;
    bottom: 0;
    left: 30px;
    opacity: 0.15;
  }

  /* Masonry Gallery */
  :global(.masonry-gallery) {
    column-count: 1;
    column-gap: 12px;
  }

  @media (min-width: 640px) {
    :global(.masonry-gallery) {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    :global(.masonry-gallery) {
      column-count: 3;
    }
  }

  @media (min-width: 1280px) {
    :global(.masonry-gallery) {
      column-count: 4;
    }
  }

  :global(.media-item) {
    break-inside: avoid;
    margin-bottom: 12px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: all var(--duration-normal) var(--ease-out);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.6s var(--ease-out) forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.media-item:hover) {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.3);
    border-color: var(--color-life);
  }

  :global(.media-img) {
    width: 100%;
    height: auto;
    display: block;
    cursor: zoom-in;
  }

  :global(.video-wrapper) {
    position: relative;
    width: 100%;
    cursor: pointer;
  }

  :global(.media-video) {
    width: 100%;
    height: auto;
    display: block;
  }

  :global(.video-overlay) {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    transition: background var(--duration-normal) var(--ease-out);
  }

  :global(.media-item:hover .video-overlay) {
    background: rgba(0, 0, 0, 0.15);
  }

  :global(.play-btn) {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-normal) var(--ease-out);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  :global(.media-item:hover .play-btn) {
    transform: scale(1.1);
    background: #fff;
  }

  :global(.play-btn svg) {
    margin-left: 4px;
  }

  /* Video Lightbox */
  :global(.video-lightbox) {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.video-lightbox-backdrop) {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  :global(.video-lightbox video) {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 85vh;
    border-radius: var(--radius-md);
  }

  :global(.video-lightbox-close) {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--duration-fast) var(--ease-out);
  }

  :global(.video-lightbox-close:hover) {
    background: rgba(255, 255, 255, 0.3);
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: var(--space-20) var(--space-4);
    color: var(--color-text-muted);
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: var(--space-4);
  }

  .empty-state code {
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* Reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity var(--duration-slow) var(--ease-out),
                transform var(--duration-slow) var(--ease-out);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initLifeReveal() {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    reveals.forEach((el) => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initLifeReveal);

  setTimeout(() => {
    document.querySelectorAll('.reveal:not(.is-visible)').forEach(el => {
      el.classList.add('is-visible');
    });
  }, 3000);
</script>
