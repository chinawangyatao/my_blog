---
import Lightfall from './react/Lightfall.tsx';
---

<section class="hero">
  <!-- Lightfall WebGL Background -->
  <div class="hero-bg">
    <Lightfall
      client:load
      colors={['#A6C8FF', '#7C3AED', '#FF9FFC']}
      backgroundColor="#0A0A12"
      speed={0.5}
      streakCount={6}
      streakWidth={1}
      streakLength={1}
      glow={1}
      density={0.8}
      twinkle={1}
      zoom={3}
      backgroundGlow={0.4}
      opacity={1}
      mouseInteraction={true}
      mouseStrength={0.5}
      mouseRadius={0.8}
    />
  </div>

  <!-- Dark overlay for text readability -->
  <div class="hero-overlay"></div>

  <div class="hero-content container">
    <div class="hero-badge reveal">
      <span class="badge-dot"></span>
      欢迎来到我的数字花园
    </div>

    <h1 class="hero-title reveal reveal-delay-1">
      嗨，我是 <span class="text-gradient-light">wxc</span><br />
      <span class="hero-subtitle">用心生活，认真编码</span>
    </h1>

    <p class="hero-description reveal reveal-delay-2">
      一个记录技术探索、生活感悟与兴趣热爱的个人空间。
      在这里，你可以看到我用代码构建的世界，
      也能感受到我对生活的好奇与热爱。
    </p>

    <div class="hero-actions reveal reveal-delay-3">
      <a href="/tech" class="btn btn-primary">
        浏览技术文章
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/about" class="btn btn-secondary">
        了解更多关于我
      </a>
    </div>

    <div class="hero-stats reveal reveal-delay-4">
      <div class="stat">
        <span class="stat-value">7+</span>
        <span class="stat-label">篇文章</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">3</span>
        <span class="stat-label">个板块</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">∞</span>
        <span class="stat-label">份热爱</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint reveal reveal-delay-5">
    <span>向下滚动探索</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--space-16) 0;
    background: #0A0A12;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(ellipse at center, transparent 0%, rgba(10, 10, 18, 0.5) 100%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-6);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: #22C55E;
    box-shadow: 0 0 8px #22C55E;
    animation: pulse-glow 2s var(--ease-in-out) infinite;
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-6);
    max-width: 800px;
    color: #fff;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: var(--text-5xl);
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: var(--text-6xl);
    }
  }

  .text-gradient-light {
    background: linear-gradient(135deg, #A6C8FF 0%, #FF9FFC 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-family: var(--font-handwritten);
    font-size: 0.65em;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    display: inline-block;
    margin-top: var(--space-2);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    max-width: 560px;
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: all var(--duration-normal) var(--ease-out);
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-primary {
    background: #fff;
    color: #0A0A12;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(255, 255, 255, 0.2);
    color: #0A0A12;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.6);
    margin-top: var(--space-1);
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.15);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
    animation: float 2s var(--ease-in-out) infinite;
  }

  @media (max-width: 767px) {
    .hero-scroll-hint {
      display: none;
    }
  }
</style>
