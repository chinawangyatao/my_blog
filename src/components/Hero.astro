---
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="hero-blob hero-blob-3"></div>
  </div>

  <div class="hero-content container">
    <div class="hero-badge reveal">
      <span class="badge-dot"></span>
      欢迎来到我的数字花园
    </div>

    <h1 class="hero-title reveal reveal-delay-1">
      嗨，我是 <span class="text-gradient">wxc</span><br />
      <span class="hero-subtitle">用心生活，认真编码</span>
    </h1>

    <p class="hero-description reveal reveal-delay-2">
      一个记录技术探索、生活感悟与兴趣热爱的个人空间。
      在这里，你可以看到我用代码构建的世界，
      也能感受到我对生活的好奇与热爱。
    </p>

    <div class="hero-actions reveal reveal-delay-3">
      <a href="/tech" class="btn btn-primary">
        浏览技术文章
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/about" class="btn btn-secondary">
        了解更多关于我
      </a>
    </div>

    <div class="hero-stats reveal reveal-delay-4">
      <div class="stat">
        <span class="stat-value">7+</span>
        <span class="stat-label">篇文章</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">3</span>
        <span class="stat-label">个板块</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">∞</span>
        <span class="stat-label">份热爱</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint reveal reveal-delay-5">
    <span>向下滚动探索</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--space-16) 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: float 8s var(--ease-in-out) infinite;
  }

  .hero-blob-1 {
    width: 400px;
    height: 400px;
    background: var(--color-tech);
    top: -100px;
    right: -100px;
  }

  .hero-blob-2 {
    width: 350px;
    height: 350px;
    background: var(--color-life);
    bottom: -50px;
    left: -100px;
    animation-delay: 2s;
  }

  .hero-blob-3 {
    width: 300px;
    height: 300px;
    background: #7C3AED;
    top: 40%;
    left: 50%;
    transform: translateX(-50%);
    animation-delay: 4s;
    opacity: 0.2;
  }

  :global(:root[data-theme="dark"]) .hero-blob {
    opacity: 0.2;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: #22C55E;
    box-shadow: 0 0 8px #22C55E;
    animation: pulse-glow 2s var(--ease-in-out) infinite;
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-6);
    max-width: 800px;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: var(--text-5xl);
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: var(--text-6xl);
    }
  }

  .hero-subtitle {
    font-family: var(--font-handwritten);
    font-size: 0.65em;
    font-weight: 500;
    color: var(--color-text-secondary);
    display: inline-block;
    margin-top: var(--space-2);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: all var(--duration-normal) var(--ease-out);
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    color: var(--color-bg);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-text);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    animation: float 2s var(--ease-in-out) infinite;
  }

  @media (max-width: 767px) {
    .hero-scroll-hint {
      display: none;
    }
    .hero {
      min-height: auto;
      padding: var(--space-12) 0;
    }
  }
</style>
