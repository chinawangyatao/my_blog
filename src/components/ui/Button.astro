---
import { type HTMLAnchorAttributes } from 'astro/types';

interface Props extends HTMLAnchorAttributes {
  variant?: 'default' | 'outline' | 'ghost' | 'gradient' | 'link';
  size?: 'default' | 'sm' | 'lg' | 'icon';
}

const {
  variant = 'default',
  size = 'default',
  class: className = '',
  ...props
} = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-semibold ring-offset-[var(--color-bg)] transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 cursor-pointer';

const variants: Record<string, string> = {
  default: 'bg-[var(--color-text)] text-[var(--color-bg)] hover:opacity-90 hover:-translate-y-0.5 hover:shadow-lg',
  outline: 'border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] hover:-translate-y-0.5 hover:shadow-md',
  ghost: 'text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text)]',
  gradient: 'text-white bg-gradient-to-r from-[var(--color-tech)] via-[var(--color-accent)] to-[var(--color-interest)] hover:shadow-lg hover:-translate-y-0.5 bg-[length:200%_auto] hover:bg-[position:100%_0]',
  link: 'text-[var(--color-accent)] underline-offset-4 hover:underline',
};

const sizes: Record<string, string> = {
  default: 'h-10 px-5 py-2',
  sm: 'h-8 px-3 text-xs',
  lg: 'h-12 px-7 text-base',
  icon: 'h-10 w-10',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

<a class={classes} {...props}>
  <slot />
</a>
