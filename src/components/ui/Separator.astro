---
import { type HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  orientation?: 'horizontal' | 'vertical';
  class?: string;
}

const {
  orientation = 'horizontal',
  class: className = '',
  ...props
} = Astro.props;

const classes =
  orientation === 'horizontal'
    ? `h-px w-full bg-[var(--color-border)] ${className}`
    : `h-full w-px bg-[var(--color-border)] ${className}`;
---

<div class={classes} role="separator" {...props}>
  <slot />
</div>
