---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: '首页' },
  { href: '/tech', label: '技术' },
  { href: '/life', label: '生活' },
  { href: '/interests', label: '兴趣' },
  { href: '/about', label: '关于' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="wxc 的博客 - 首页">
      <span class="logo-mark">w</span>
      <span class="logo-text">wxc<span class="logo-dot">.</span>dev</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" aria-label="主导航">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--color-bg) 70%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
    height: var(--header-height);
    display: flex;
    align-items: center;
    transition: box-shadow var(--duration-normal) var(--ease-out),
                background var(--duration-normal) var(--ease-out),
                border-color var(--duration-normal) var(--ease-out);
  }

  .site-header.scrolled {
    box-shadow: 0 8px 32px -12px rgba(0, 0, 0, 0.2);
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    border-bottom-color: color-mix(in srgb, var(--color-border) 80%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    width: 100%;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-text);
    cursor: pointer;
    flex-shrink: 0;
  }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg, #38BDF8 0%, #C084FC 100%);
    color: #fff;
    font-size: var(--text-base);
    font-weight: 800;
    box-shadow: 0 4px 14px -3px color-mix(in srgb, #38BDF8 50%, transparent);
    transition: transform var(--duration-normal) var(--ease-spring),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .logo:hover .logo-mark {
    transform: rotate(-8deg) scale(1.05);
    box-shadow: 0 6px 18px -3px color-mix(in srgb, #C084FC 55%, transparent);
  }

  .logo-text {
    letter-spacing: var(--tracking-tight);
  }

  .logo-dot {
    color: var(--color-accent);
  }

  /* Desktop Nav - glass pill */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 4px;
    padding: 5px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-surface) 50%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-border) 40%, transparent);
  }

  .nav-link {
    position: relative;
    padding: 8px 26px;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-secondary);
    border-radius: 9999px;
    transition: color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-text) 7%, transparent);
  }

  .nav-link.active {
    color: #FAFAFA;
    background: #3F3F46;
    font-weight: 600;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06),
                0 2px 8px -2px rgba(0, 0, 0, 0.3);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }
</style>

<script>
  let scrollHandler: (() => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('site-header');
    if (!header) return;

    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }

    scrollHandler = () => {
      if (window.scrollY > 8) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };

    scrollHandler();
    window.addEventListener('scroll', scrollHandler, { passive: true });
  });
</script>
